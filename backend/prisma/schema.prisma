generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  teacher
  coach
  student
}

enum PaymentStatus {
  pending
  approved
  rejected
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  className    String?   @map("class_name") @db.VarChar(64)
  lastLoginAt  DateTime? @map("last_login_at")
  lastLoginIp  String?   @map("last_login_ip")

  fideId               String?   @map("fide_id")
  mcfId                String?   @map("mcf_id")
  fideStandardRating   Int?      @map("fide_standard_rating")
  fideRapidRating      Int?      @map("fide_rapid_rating")
  fideBlitzRating      Int?      @map("fide_blitz_rating")
  fideRatingFetchedAt  DateTime? @map("fide_rating_fetched_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessionsCreated    Session[]       @relation("CreatedBy")
  sessionsCancelled  Session[]       @relation("CancelledBy")
  preAttendances    PreAttendance[] @relation("StudentPreAttendance")
  attendances       Attendance[]    @relation("StudentAttendance")
  attendancesMarked Attendance[]    @relation("MarkedBy")
  payments          Payment[]       @relation("StudentPayment")
  paymentsReviewed  Payment[]       @relation("ReviewedBy")
  appConfigsUpdated   AppConfig[]           @relation("ConfigUpdatedBy")
  notifications       Notification[]
  tournamentsCreated  Tournament[]          @relation("TournamentCreatedBy")
  tournamentInterests TournamentInterest[]  @relation("TournamentInterest")
  pollsCreated        Poll[]                @relation("PollCreatedBy")
  votes               Vote[]                @relation("UserVotes")
  resourcesCreated    Resource[]            @relation("ResourceCreatedBy")
  gamesCreated        Game[]                @relation("GameCreatedBy")
  puzzleAttempts      PuzzleAttempt[]       @relation("PuzzleAttempts")
  competitionRecords        CompetitionRecord[] @relation("studentRecords")
  createdCompetitionRecords CompetitionRecord[] @relation("recordCreator")

  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  date          DateTime  @db.Date
  startTime     DateTime  @map("start_time")
  endTime       DateTime  @map("end_time")
  place         String
  notes         String?
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  isCancelled   Boolean   @default(false) @map("is_cancelled")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById String?   @map("cancelled_by_id")

  createdBy      User            @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  cancelledBy    User?           @relation("CancelledBy", fields: [cancelledById], references: [id], onDelete: Restrict)
  preAttendances PreAttendance[]
  attendances    Attendance[]
  payments       Payment[]

  @@index([date])
  @@map("sessions")
}

model PreAttendance {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  studentId   String   @map("student_id")
  confirmedAt DateTime @default(now()) @map("confirmed_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User    @relation("StudentPreAttendance", fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([sessionId, studentId])
  @@map("pre_attendances")
}

model Attendance {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  studentId  String   @map("student_id")
  present    Boolean  @default(false)
  paidCash   Boolean  @default(false) @map("paid_cash")
  markedById String   @map("marked_by_id")
  markedAt   DateTime @default(now()) @map("marked_at")

  session  Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student  User    @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Restrict)
  markedBy User    @relation("MarkedBy", fields: [markedById], references: [id], onDelete: Restrict)

  @@unique([sessionId, studentId])
  @@map("attendances")
}

model Payment {
  id              String        @id @default(uuid())
  studentId       String        @map("student_id")
  sessionId       String?       @map("session_id")
  amount          Decimal       @db.Decimal(10, 2)
  receiptFilePath String?       @map("receipt_file_path")
  status          PaymentStatus @default(pending)
  uploadedAt      DateTime      @default(now()) @map("uploaded_at")
  reviewedById    String?       @map("reviewed_by_id")
  reviewedAt      DateTime?     @map("reviewed_at")

  student    User     @relation("StudentPayment", fields: [studentId], references: [id], onDelete: Restrict)
  session    Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  reviewedBy User?    @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([status])
  @@map("payments")
}

model AppConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedById String   @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User @relation("ConfigUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@map("app_configs")
}

enum NotificationType {
  session_created
  pre_attendance_set
  attendance_marked_present
  paid_cash
  receipt_uploaded
  payment_reviewed
  tournament_added
  poll_created
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  linkPath  String?          @map("link_path")
  payload   Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Tournament {
  id               String    @id @default(uuid())
  name             String    @db.VarChar(200)
  description      String
  imagePath        String?   @map("image_path")
  place            String?   @db.VarChar(200)
  registrationLink String?   @map("registration_link")
  bskkLetterPath   String?   @map("bskk_letter_path")
  kpmLetterPath    String?   @map("kpm_letter_path")
  resultUrl        String?   @map("result_url")
  targetPajsk      PajskTarget @default(tiada) @map("target_pajsk")
  startDate        DateTime? @map("start_date") @db.Date
  endDate          DateTime? @map("end_date") @db.Date
  createdById      String    @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  createdBy User                @relation("TournamentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  interests TournamentInterest[]

  @@index([startDate])
  @@map("tournaments")
}

model TournamentInterest {
  id           String   @id @default(uuid())
  tournamentId String   @map("tournament_id")
  studentId    String   @map("student_id")
  confirmedAt  DateTime @default(now()) @map("confirmed_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  student    User       @relation("TournamentInterest", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, studentId])
  @@map("tournament_interests")
}

model Poll {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200)
  description String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User         @relation("PollCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  options   PollOption[]
  votes     Vote[]

  @@index([endDate])
  @@map("polls")
}

model PollOption {
  id        String  @id @default(uuid())
  pollId    String  @map("poll_id")
  label     String  @db.VarChar(200)
  imagePath String? @map("image_path")
  order     Int     @default(0)

  poll  Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@index([pollId])
  @@map("poll_options")
}

model Vote {
  id        String   @id @default(uuid())
  pollId    String   @map("poll_id")
  optionId  String   @map("option_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
  @@map("votes")
}

enum ResourceType {
  book
  homework
  app
}

model Resource {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(200)
  type        ResourceType
  description String?
  imagePath   String?      @map("image_path")
  filePath    String?      @map("file_path")
  fileName    String?      @map("file_name") @db.VarChar(255)
  fileMime    String?      @map("file_mime") @db.VarChar(100)
  url         String?
  isEnabled   Boolean      @default(true) @map("is_enabled")
  createdById String       @map("created_by_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  createdBy User @relation("ResourceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([isEnabled])
  @@map("resources")
}

enum GameResult {
  white_win @map("1-0")
  black_win @map("0-1")
  draw      @map("1/2-1/2")
}

model Game {
  id             String     @id @default(uuid())
  tournamentName String     @map("tournament_name") @db.VarChar(200)
  whitePlayer    String     @map("white_player") @db.VarChar(120)
  blackPlayer    String     @map("black_player") @db.VarChar(120)
  result         GameResult
  pgn            String     @db.Text
  eventDate      DateTime?  @map("event_date") @db.Date
  whiteElo       Int?       @map("white_elo")
  blackElo       Int?       @map("black_elo")
  opening        String?    @db.VarChar(120)
  notes          String?    @db.Text
  createdById    String     @map("created_by_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  createdBy User @relation("GameCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([tournamentName])
  @@map("games")
}

enum PuzzleAttemptStatus {
  solved
  failed
  gave_up
}

model Puzzle {
  id              String   @id @default(uuid())
  externalId      String   @unique @map("external_id")
  fen             String   @db.VarChar(120)
  solutionUci     String   @map("solution_uci")
  rating          Int
  ratingDeviation Int?     @map("rating_deviation")
  popularity      Int?
  themes          String?  @db.Text
  openingTags     String?  @map("opening_tags") @db.Text
  gameUrl         String?  @map("game_url")
  createdAt       DateTime @default(now()) @map("created_at")

  attempts PuzzleAttempt[]

  @@index([rating])
  @@map("puzzles")
}

model PuzzleAttempt {
  id          String              @id @default(uuid())
  puzzleId    String              @map("puzzle_id")
  userId      String              @map("user_id")
  status      PuzzleAttemptStatus
  movesTaken  Int                 @map("moves_taken")
  timeMs      Int                 @map("time_ms")
  isFirstTry  Boolean             @map("is_first_try")
  attemptedOn DateTime            @db.Date @map("attempted_on")

  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  user   User   @relation("PuzzleAttempts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, attemptedOn])
  @@index([puzzleId])
  @@map("puzzle_attempts")
}

enum CompetitionLevel {
  sekolah
  daerah
  negeri
  kebangsaan
  antarabangsa
}

enum PajskTarget {
  tiada
  sekolah
  daerah
  negeri
  kebangsaan
  antarabangsa
}

enum CompetitionCategory {
  u13
  u14
  u15
  u16
  u17
  u18
  u21
  open
}

model CompetitionRecord {
  id              String              @id @default(cuid())
  studentId       String              @map("student_id")
  createdById     String              @map("created_by_id")
  competitionName String              @map("competition_name")
  competitionDate DateTime            @map("competition_date") @db.Date
  level           CompetitionLevel
  pajsk           Boolean             @default(false)
  fideRated       Boolean             @default(false) @map("fide_rated")
  mcfRated        Boolean             @default(false) @map("mcf_rated")
  category        CompetitionCategory
  placement       Int?
  imagePath       String?             @map("image_path")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  student   User @relation("studentRecords", fields: [studentId], references: [id], onDelete: Restrict)
  createdBy User @relation("recordCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([competitionDate])
  @@map("competition_records")
}
