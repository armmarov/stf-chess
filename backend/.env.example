PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/stf_chess
JWT_SECRET=change-me-to-a-long-random-secret
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000
# Path where uploaded receipts are stored. Must be writable by the Node process.
# Defaults to backend/uploads in local dev. Production example: /opt/stf/data
UPLOADS_DIR=
