NODE_ENV=test
PORT=3001

# Both point at the same test DB — app/service uses DATABASE_URL, test helpers use DATABASE_URL_TEST
DATABASE_URL=postgresql://postgres:password@localhost:5432/stf_test
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/stf_test

JWT_SECRET=test-jwt-secret-must-be-at-least-16-chars
CORS_ORIGIN=http://localhost:5173

# Lower rate-limit max so the 429 test stays fast (3 bad requests → 4th is 429)
AUTH_RATE_LIMIT_MAX=3

# Path for uploaded receipts in test runs. Use /tmp to avoid polluting the repo.
UPLOADS_DIR=/tmp/stf-test-uploads
